# dependencies
/node_modules

# testing
/coverage

# production
/build
/dist

# vite / typescript
*.tsbuildinfo

# local env files (keep .env.example tracked)
.env
.env.*
!.env.example

# Claude Code local files (keep shared .claude/settings.json tracked)
.claude/settings.local.json
.claude/*.local.json

# misc
.DS_Store

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.idea
ABOUT.md

# wrangler local state + local secrets
.wrangler/
.dev.vars
.dev.vars.*

# Legacy SVG masters are bootstrap inputs for generator/verify.ts only —
# transient working files dropped in per reconstruction batch. Jason keeps the
