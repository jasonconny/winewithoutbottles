# Copy this file to `.env.local` and fill in values.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle
# (via import.meta.env.VITE_*). Anything in the client is PUBLIC — never
# put secrets here. Server-side secrets belong in a backend/serverless env.

# Example: base URL of an API this app talks to.
# VITE_API_BASE_URL=https://api.example.com
