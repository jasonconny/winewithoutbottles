{
  "name": "winewithoutbottles",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
